# beta gateway port on ECS
BETA_HTTP_PORT=80

# backend internal port in container
BACKEND_PORT=18080
SPRING_PROFILES_ACTIVE=prod

# app base url for email links
APP_BASE_URL=http://<your-ecs-ip-or-domain>
COOKIE_SECURE=false

# database (recommend separate beta database)
SPRING_DATASOURCE_URL=jdbc:mysql://<rds-endpoint>:3306/personal_english_ai_beta?useUnicode=true&characterEncoding=utf8&useSSL=false&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true
SPRING_DATASOURCE_USERNAME=<db_user>
SPRING_DATASOURCE_PASSWORD=<db_password>

DB_HOST=<rds-endpoint>
DB_PORT=3306
DB_NAME=personal_english_ai_beta
DB_USER=<db_user>
DB_PASSWORD=<db_password>

# jwt (must be long random string)
JWT_SECRET=<replace-with-64+chars-random-string>
JWT_ACCESS_TOKEN_SECONDS=7200
JWT_REFRESH_TOKEN_SECONDS=604800

# openai
OPENAI_API_KEY=<your_openai_api_key>
OPENAI_BASE_URL=https://api.openai.com
OPENAI_PROXY_ENABLED=false
OPENAI_PROXY_URL=
OPENAI_PROXY_HOST=
OPENAI_PROXY_PORT=

# optional providers
SAPLING_ENABLED=false
SAPLING_API_KEY=
SAPLING_BASE_URL=https://api.sapling.ai

QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode
QWEN_MODEL=qwen-plus
QWEN_VL_MODEL=qwen-vl-plus

# sidecar
AI_CONTEXT_CONVERSATION_PROCESSOR=hybrid
AI_CONTEXT_CONVERSATION_PYTHON_ENABLED=true
AI_CONTEXT_CONVERSATION_PYTHON_TIMEOUT_MS=800
AI_CONTEXT_CONVERSATION_PYTHON_FALLBACK_ENABLED=true
CONTEXT_SIDECAR_REDIS_TTL_SECONDS=86400
CONTEXT_SIDECAR_REDIS_MAX_MESSAGES=50
CONTEXT_SIDECAR_DEFAULT_RECENT_TURNS=8

# optional mail
MAIL_ENABLED=false
MAIL_FROM=noreply@mail.personalenglishai.com
MAIL_HOST=
MAIL_PORT=465
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_SSL_ENABLE=true
MAIL_STARTTLS_ENABLE=false
