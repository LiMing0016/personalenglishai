# ==================================================
# Runtime
# ==================================================
SPRING_PROFILES_ACTIVE=dev
SERVER_PORT=18080

# ==================================================
# Database
# ==================================================
SPRING_DATASOURCE_URL=jdbc:mysql://127.0.0.1:3306/personal_english_ai?useUnicode=true&characterEncoding=utf8&useSSL=false&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=your_db_password_here

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=personal_english_ai
DB_USER=root
DB_PASSWORD=your_db_password_here

# ==================================================
# Auth
# ==================================================
# Generate with: openssl rand -hex 32
JWT_SECRET=replace_with_strong_random_secret_64_hex_chars
JWT_ACCESS_TOKEN_SECONDS=7200
JWT_REFRESH_TOKEN_SECONDS=604800

# ==================================================
# OpenAI
# ==================================================
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com

OPENAI_PROXY_ENABLED=false
OPENAI_PROXY_URL=http://127.0.0.1:59527
OPENAI_PROXY_HOST=127.0.0.1
OPENAI_PROXY_PORT=59527

# ==================================================
# Prompt & AI Config
# ==================================================
AI_PROMPT_DEBUG=true
AI_PROMPT_LOG_RAW_ENABLED=false
AI_PROMPT_LOG_RAW_MAX_CHARS=12000
AI_PROMPT_CONTEXT_SELECTED_TEXT_MAX=1200
AI_PROMPT_CONTEXT_RECENT_EACH_MAX=200
AI_PROMPT_CONTEXT_RECENT_TURNS=8
AI_PROMPT_CONTEXT_DRAFT_MAX=1600

AI_CONTEXT_CONVERSATION_PROCESSOR=hybrid
AI_CONTEXT_CONVERSATION_PYTHON_ENABLED=true
AI_CONTEXT_CONVERSATION_PYTHON_BASE_URL=http://127.0.0.1:8001
AI_CONTEXT_CONVERSATION_PYTHON_TIMEOUT_MS=800
AI_CONTEXT_CONVERSATION_PYTHON_FALLBACK_ENABLED=true

AI_REPAIR_ENABLED=false

AI_ENDPOINT_MODE=responses
AI_MODEL=gpt-4o-mini
AI_FALLBACK_MODEL=gpt-4o-mini

# ==================================================
# Mail (SMTP)
# ==================================================
MAIL_ENABLED=false
MAIL_FROM=noreply@mail.personalenglishai.com
MAIL_HOST=smtpdm.aliyun.com
MAIL_PORT=465
MAIL_USERNAME=noreply@mail.personalenglishai.com
MAIL_PASSWORD=your_mail_password_here
MAIL_SSL_ENABLE=true
MAIL_STARTTLS_ENABLE=false

# ==================================================
# Cookie (set true in production with HTTPS)
# ==================================================
COOKIE_SECURE=false

# Frontend base URL (used in email verification links)
APP_BASE_URL=http://localhost:5173
