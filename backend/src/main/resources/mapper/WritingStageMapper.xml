<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.personalenglishai.backend.mapper.WritingStageMapper">

    <resultMap id="BaseResultMap" type="com.personalenglishai.backend.entity.WritingStage">
        <id property="id" column="id"/>
        <result property="code" column="code"/>
        <result property="name" column="name"/>
        <result property="minWordCount" column="min_word_count"/>
        <result property="sortOrder" column="sort_order"/>
        <result property="isActive" column="is_active"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <select id="selectAllActive" resultMap="BaseResultMap">
        SELECT id, code, name, min_word_count, sort_order, is_active, created_at, updated_at
        FROM writing_stage
        WHERE is_active = 1
        ORDER BY sort_order ASC, id ASC
    </select>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT id, code, name, min_word_count, sort_order, is_active, created_at, updated_at
        FROM writing_stage
        WHERE id = #{id}
    </select>

    <select id="selectByCode" resultMap="BaseResultMap">
        SELECT id, code, name, min_word_count, sort_order, is_active, created_at, updated_at
        FROM writing_stage
        WHERE code = #{code}
        LIMIT 1
    </select>
</mapper>
