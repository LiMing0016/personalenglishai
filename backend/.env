# ==================================================
# OpenAI
# ==================================================
# API Key (local only, do not commit to git)
OPENAI_API_KEY=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

# OpenAI base URL
OPENAI_BASE_URL=https://api.openai.com

# Proxy config (enable when direct connection is blocked)
# true = use proxy; false = direct to OPENAI_BASE_URL
OPENAI_PROXY_ENABLED=true

# Full proxy URL (preferred)
OPENAI_PROXY_URL=http://127.0.0.1:59527

# Compat fields (if code reads host/port separately)
OPENAI_PROXY_HOST=127.0.0.1
OPENAI_PROXY_PORT=59527

# ==================================================
# Prompt Observability
# ==================================================
# true = print prompt build summary (not full text)
AI_PROMPT_DEBUG=true

# true = print raw system/user text sent to model (local debug only)
# Risk: logs may contain user privacy & long text; production must be false
AI_PROMPT_LOG_RAW_ENABLED=false

# Max chars for raw prompt log (prevent log explosion)
AI_PROMPT_LOG_RAW_MAX_CHARS=12000

# Context segment max lengths (chars)
AI_PROMPT_CONTEXT_SELECTED_TEXT_MAX=1200
AI_PROMPT_CONTEXT_RECENT_EACH_MAX=200
AI_PROMPT_CONTEXT_RECENT_TURNS=8
AI_PROMPT_CONTEXT_DRAFT_MAX=1600

# ==================================================
# Conversation Context Processor
# ==================================================
# rule = Java rules; python = Python sidecar; hybrid = Python first, fallback to Java
AI_CONTEXT_CONVERSATION_PROCESSOR=hybrid

# Enable Python context sidecar
AI_CONTEXT_CONVERSATION_PYTHON_ENABLED=true

# Python sidecar address (default 8001)
AI_CONTEXT_CONVERSATION_PYTHON_BASE_URL=http://127.0.0.1:8001

# Python sidecar call timeout (ms)
AI_CONTEXT_CONVERSATION_PYTHON_TIMEOUT_MS=800

# true = fallback to local rules when Python fails
AI_CONTEXT_CONVERSATION_PYTHON_FALLBACK_ENABLED=true

# ==================================================
# Repair
# ==================================================
# true = enable second-pass repair (JSON format fix); false = off
AI_REPAIR_ENABLED=false

# ==================================================
# OpenAI Endpoint Mode
# ==================================================
# responses = /v1/responses (recommended for GPT-5)
# chat_completions = /v1/chat/completions (legacy)
AI_ENDPOINT_MODE=responses
AI_MODEL=gpt-4o
AI_FALLBACK_MODEL=gpt-4o

# GPT-5 recommended timeout profile (evaluate path)
OPENAI_RESPONSE_TIMEOUT_MS=60000
OPENAI_OVERALL_TIMEOUT_MS=150000
OPENAI_MAX_RETRIES=1
OPENAI_INITIAL_BACKOFF_MS=300
OPENAI_MAX_BACKOFF_MS=1000

# ==================================================
# Mail (Aliyun DirectMail SMTP)
# ==================================================
# true = use real SMTP sender for register/forgot-password emails
MAIL_ENABLED=true
MAIL_FROM=noreply@mail.personalenglishai.com
MAIL_HOST=smtpdm.aliyun.com
MAIL_PORT=465
MAIL_USERNAME=noreply@mail.personalenglishai.com
# Use DirectMail SMTP password from Alibaba Cloud console (not mailbox login password)
MAIL_PASSWORD=GUOyanquan0016
MAIL_SSL_ENABLE=true
MAIL_STARTTLS_ENABLE=false

# ==================================================
# Sapling AI (grammar checker)
# ==================================================
SAPLING_ENABLED=true
SAPLING_API_KEY=49RYKC7PIW47N5VB9RXIZDEP32IML5ND
