DB_USER=root
DB_PASSWORD=967850

# ==================================================
# Auth
# ==================================================
# JWT secret (generated with: openssl rand -hex 32)
JWT_SECRET=9d217ea0efe4213a0b6941248b655d18238124f8228a0f2a5014aa0bf701c00f

# JWT expiry
JWT_EXPIRE_SECONDS=86400
# Access token: 2 hours (writing sessions can be long)
JWT_ACCESS_TOKEN_SECONDS=7200
# Refresh token: 7 days
